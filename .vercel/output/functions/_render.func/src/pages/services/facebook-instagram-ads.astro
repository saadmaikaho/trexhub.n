---
import MainLayout from "../../layouts/MainLayout.astro";
import Card from "../../components/ui/Card.astro";
import { Image } from "astro:assets";

import serviceImg from "../../assets/pics/card-pic2.png";
import icon1 from "../../assets/icon1.svg";
import icon2 from "../../assets/icon2.svg";
import icon3 from "../../assets/icon3.svg";
import icon4 from "../../assets/icon4.svg";

const includes = [
  {
    title: "Campaign Strategy",
    items: ["Audience research & persona building", "Competitor ad analysis", "Funnel mapping (awareness → conversion)", "Budget allocation planning"],
  },
  {
    title: "Ad Creative & Copy",
    items: ["Scroll-stopping ad creatives", "Conversion-focused ad copy", "A/B testing of creatives", "Video & image ad formats"],
  },
  {
    title: "Targeting & Retargeting",
    items: ["Custom & lookalike audiences", "Interest & behaviour targeting", "Website retargeting (Pixel)", "Warm audience re-engagement"],
  },
];

const process = [
  { title: "Audience Research", description: "We identify exactly who your ideal customers are — demographics, interests, behaviours — so every naira of ad spend reaches the right people.", icon: icon1 },
  { title: "Creative Production", description: "We craft compelling ad creatives and copy designed to stop the scroll and drive action, tailored to each stage of your funnel.", icon: icon2 },
  { title: "Launch & Optimise", description: "We launch campaigns, monitor performance daily, and make data-backed adjustments to continuously improve your ROAS.", icon: icon3 },
  { title: "Report & Scale", description: "You get clear reports showing exactly what's working. We then scale winning campaigns to maximise your results.", icon: icon4 },
];

const faqs = [
  { question: "How much should I spend on Facebook Ads?", answer: "We recommend a minimum budget of ₦150,000/month to generate meaningful data and results. However, we'll work with your budget and advise on the best allocation based on your goals and industry." },
  { question: "How quickly will I see results?", answer: "Most clients start seeing leads and conversions within the first 2 weeks. The first month is typically a learning phase where we optimise targeting and creatives for peak performance." },
  { question: "Do you handle the ad creatives too?", answer: "Yes. Our team handles strategy, copywriting, and creative direction. We'll need your brand assets (logo, colours, product images) and we take it from there." },
  { question: "What's ROAS and what should I expect?", answer: "ROAS (Return on Ad Spend) measures revenue generated per naira spent on ads. Our clients typically achieve 4x–10x ROAS depending on the industry, offer, and funnel quality." },
];
---

<MainLayout
  title="Facebook & Instagram Ads Management in Lagos | TrexHub"
  description="High-converting Facebook and Instagram ad campaigns for Nigerian businesses. TrexHub manages your Meta ads from strategy to creative to scaling."
>
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">

    <!-- Hero -->
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24">
      <div>
        <span class="inline-block bg-[#b9ff66] text-black text-sm font-medium px-4 py-1 rounded-full mb-4">Meta Ads Management</span>
        <h1 class="mb-6 text-4xl font-medium leading-tight md:text-5xl lg:text-6xl">Facebook & Instagram Ads That Actually Convert</h1>
        <p class="mb-8 text-lg font-normal text-gray-700">
          Stop wasting ad spend on clicks that don't convert. TrexHub builds and manages Facebook and Instagram campaigns that reach the right audience and turn them into paying customers.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/#contact" class="inline-flex items-center justify-center px-8 py-4 bg-black text-white rounded-2xl hover:bg-[#b9ff66] hover:text-black transition-all font-medium text-lg">
            Launch My Campaign
          </a>
          <a href="#process" class="inline-flex items-center justify-center px-8 py-4 bg-[#f3f3f3] text-black rounded-2xl hover:bg-black hover:text-white transition-all font-medium text-lg">
            See Our Process
          </a>
        </div>
        <div class="flex gap-8 mt-8">
          <div><p class="text-2xl font-medium">8x</p><p class="text-sm text-gray-500">Average ROAS</p></div>
          <div><p class="text-2xl font-medium">₦2B+</p><p class="text-sm text-gray-500">Ad Spend Managed</p></div>
          <div><p class="text-2xl font-medium">200+</p><p class="text-sm text-gray-500">Campaigns Launched</p></div>
        </div>
      </div>
      <div class="relative">
        <div class="bg-[#b9ff66] rounded-[45px] p-4 md:p-8 relative z-10">
          <Image src={serviceImg} alt="Facebook & Instagram Ads" class="w-full h-auto rounded-[35px]" />
        </div>
        <div class="absolute top-8 left-8 right-8 bottom-8 bg-black rounded-[45px] -z-10"></div>
      </div>
    </div>

    <!-- What's included -->
    <div class="mb-24">
      <h2 class="mb-4 text-3xl font-medium text-center">What's Included</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">Everything you need to run profitable Meta ad campaigns — from strategy to creative to optimisation.</p>
      <div class="grid md:grid-cols-3 gap-8">
        {includes.map((col) => (
          <Card>
            <div class="p-8">
              <h3 class="text-xl font-medium mb-5">{col.title}</h3>
              <ul class="space-y-3">
                {col.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="w-2 h-2 rounded-full bg-[#b9ff66] flex-shrink-0 mt-2"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <!-- Process -->
    <div class="mb-24" id="process">
      <h2 class="mb-12 text-3xl font-medium text-center">Our Process</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map((step, i) => (
          <div class="bg-[#f3f3f3] rounded-2xl p-8 relative">
            <div class="absolute -top-5 left-8 bg-black text-white w-10 h-10 rounded-full flex items-center justify-center font-medium">{i + 1}</div>
            <Image src={step.icon} alt={step.title} class="h-10 w-auto mb-4 mt-2" />
            <h3 class="text-lg font-medium mb-3">{step.title}</h3>
            <p class="text-sm text-gray-600">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- FAQs -->
    <div class="mb-24">
      <h2 class="mb-12 text-3xl font-medium text-center">Frequently Asked Questions</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {faqs.map((faq) => (
          <Card>
            <div class="p-8">
              <h3 class="text-lg font-medium mb-3">{faq.question}</h3>
              <p class="text-gray-600">{faq.answer}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <Card>
      <div class="p-10 md:p-16 text-center">
        <h2 class="text-3xl md:text-4xl font-medium mb-4">Ready to run ads that actually work?</h2>
        <p class="mb-8 text-lg text-gray-600 max-w-2xl mx-auto">Book a free strategy call and we'll show you exactly how we'd approach your Facebook & Instagram campaigns.</p>
        <a href="/#contact" class="inline-flex items-center px-10 py-5 bg-black text-white rounded-2xl hover:bg-[#b9ff66] hover:text-black transition-all font-medium text-xl">
          Book a Free Strategy Call
        </a>
      </div>
    </Card>

  </div>
</MainLayout>
