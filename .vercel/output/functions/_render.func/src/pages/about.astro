---
import MainLayout from "../layouts/MainLayout.astro";
import Sponsors from "../components/sections/Sponsors.astro";
import Services from "../components/sections/Services.astro";
---

<MainLayout title="About TrexHub | Digital Marketing Agency in Lagos, Nigeria">
  <main>

    <!-- Hero -->
    <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">
      <div class="max-w-4xl mx-auto text-center space-y-6">
        <span class="inline-block bg-[#b9ff66] text-black text-sm font-medium px-4 py-1 rounded-full">About Us</span>
        <h1 class="text-5xl font-medium leading-tight md:text-6xl">
          We Are TrexHub
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed max-w-3xl mx-auto">
          More than a Digital Marketing Agency — think of us as the bridge between attention and actual results. Most marketing agencies drive clicks. We drive action.
        </p>
        <a href="/#contact" class="inline-flex px-9 py-5 bg-black hover:bg-[#b9ff66] hover:text-black text-white rounded-2xl text-xl font-normal transition-all duration-200">
          Book a Free Strategy Call
        </a>
      </div>
    </div>

    <!-- About statement -->
    <div class="bg-[#191a23] text-white py-20 px-4">
      <div class="max-w-screen-xl mx-auto lg:px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="space-y-6">
            <h2 class="text-3xl md:text-4xl font-medium leading-tight">
              Every strategy we build has one clear goal —
              <span class="text-[#b9ff66]"> turning interest into income.</span>
            </h2>
            <p class="text-gray-300 text-lg leading-relaxed">
              At TrexHub, a Lagos, Nigeria-based digital marketing agency, every strategy — Facebook Ads, Google Ads, SEO, and Social Media — is built with one clear goal: turning interest into income.
            </p>
            <p class="text-gray-300 text-lg leading-relaxed">
              We know your business isn't just about visibility; it's about real momentum. That's why we blend global insights with local understanding — helping your brand speak directly to the people who matter most.
            </p>
            <p class="text-[#b9ff66] text-lg font-medium">
              No buzzwords. No fluff. Just honest, smart marketing with measurable payoff.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-6">
            <div class="bg-[#b9ff66] text-black rounded-2xl p-8 text-center">
              <p class="text-4xl font-medium">500K+</p>
              <p class="text-sm font-medium mt-1">Leads Generated</p>
            </div>
            <div class="bg-white text-black rounded-2xl p-8 text-center">
              <p class="text-4xl font-medium">200+</p>
              <p class="text-sm font-medium mt-1">Clients Served</p>
            </div>
            <div class="bg-white text-black rounded-2xl p-8 text-center">
              <p class="text-4xl font-medium">8x</p>
              <p class="text-sm font-medium mt-1">Average ROAS</p>
            </div>
            <div class="bg-[#b9ff66] text-black rounded-2xl p-8 text-center">
              <p class="text-4xl font-medium">5+</p>
              <p class="text-sm font-medium mt-1">Years in Business</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- What makes us different -->
    <div class="py-20 px-4 mx-auto max-w-screen-xl lg:px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-medium mb-4">What Makes TrexHub Different</h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">We're not here to impress you with reports. We're here to grow your business.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-[#f3f3f3] rounded-2xl p-8">
          <div class="w-12 h-12 bg-[#b9ff66] rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="text-xl font-medium mb-3">Results Over Vanity Metrics</h3>
          <p class="text-gray-600">We don't celebrate impressions and reach. We celebrate leads, sales, and revenue. Every campaign is measured by what it puts in your pocket.</p>
        </div>
        <div class="bg-[#191a23] text-white rounded-2xl p-8">
          <div class="w-12 h-12 bg-[#b9ff66] rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-xl font-medium mb-3">Local Knowledge, Global Standards</h3>
          <p class="text-gray-300">We understand the Nigerian market — the culture, the consumer behaviour, the platforms that work. We apply global best practices with local precision.</p>
        </div>
        <div class="bg-[#f3f3f3] rounded-2xl p-8">
          <div class="w-12 h-12 bg-[#b9ff66] rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
          <h3 class="text-xl font-medium mb-3">A Team That Actually Cares</h3>
          <p class="text-gray-600">You get a dedicated team — not a junior account manager reading from a script. We treat your business like our own and stay accountable to your growth.</p>
        </div>
      </div>
    </div>

    <Sponsors />
    <Services />

    <!-- Final CTA -->
    <div class="py-20 px-4 mx-auto max-w-screen-xl lg:px-6">
      <div class="bg-[#191a23] text-white rounded-[45px] p-12 md:p-20 text-center">
        <h2 class="text-3xl md:text-4xl font-medium mb-4">Ready to work with a team that delivers?</h2>
        <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">Book a free 30-minute strategy call. We'll review your current marketing, identify the gaps, and show you exactly how TrexHub can grow your business.</p>
        <a href="/#contact" class="inline-flex px-10 py-5 bg-[#b9ff66] text-black rounded-2xl text-xl font-medium hover:bg-white transition-all duration-200">
          Book a Free Strategy Call
        </a>
      </div>
    </div>

  </main>
</MainLayout>
