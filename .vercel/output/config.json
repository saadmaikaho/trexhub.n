{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/500/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/articles/api/search\\.json/?$",
			"dest": "_render"
		},
		{
			"src": "^/articles/search/?$",
			"dest": "_render"
		},
		{
			"src": "^/articles/tag(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/articles/?$",
			"dest": "_render"
		},
		{
			"src": "^/articles(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/invoice/?$",
			"dest": "_render"
		},
		{
			"src": "^/pricing/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacy-policy/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/email-whatsapp-marketing/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/facebook-instagram-ads/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/google-ads-ppc/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/growth-marketing-lead-generation/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/seo/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/social-media-marketing/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/?$",
			"dest": "_render"
		},
		{
			"src": "^/terms-of-service/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}