<Section id="testimonials">
  <div class="mt-20">
    <SectionTitle
      sectionTitle="Client Results"
      description="Don't take our word for it — here's what our clients say about working with TrexLead"
    />
    <div class="rounded-[45px] bg-dark mb-[150px] text-gray">
      <SwiperSlider />
    </div>
  </div>
</Section>
