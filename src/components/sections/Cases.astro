---
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Section from "./Section.astro";

const cards = [
  {
    index: 0,
    title:
      "For a Lagos real estate developer, we ran targeted Facebook & Google Ads that generated 320 qualified buyer leads in 60 days — resulting in 18 property sales and ₦680M in revenue.",
    link: "/articles",
  },
  {
    index: 1,
    title:
      "For a Nigerian e-commerce brand, we built a full-funnel SEO and retargeting strategy that grew organic traffic by 340% and increased monthly revenue from ₦2M to ₦14.5M in 5 months.",
    link: "/articles",
  },
  {
    index: 2,
    title:
      "For a B2B fintech startup in Lagos, we launched a Google Ads and LinkedIn campaign that delivered 150 demo bookings in the first quarter, cutting their cost-per-lead by 55%.",
    link: "/articles",
  },
];

import larrow from "../../assets/icon3.svg";
import SectionTitle from "../ui/SectionTitle.astro";
---

<Section id="cases">
  <SectionTitle
    sectionTitle="Case Studies"
    description="Real results for real businesses. Here's what we've achieved for our clients."
  />
  <div class="flex flex-col lg:flex-row justify-between rounded-[45px] p-1">
    {
      cards.map((card) => (
        <Card>
          <div class="flex p-[60px] h-full bg-dark text-gray rounded-[45px] m-[1px]">
            <div class="flex flex-col gap-5">
              <p>{card.title}</p>
              <a href={card.link} class="flex items-center gap-[15px]">
                <span class="text-green">Read Case Study</span>
                <picture>
                  <Image src={larrow} alt="Arrow pointing up right" />
                </picture>
              </a>
            </div>
          </div>
        </Card>
      ))
    }
  </div>
</Section>
