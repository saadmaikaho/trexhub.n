---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import HeroIlust from "../../assets/pics/hero.svg";
---

<Section id="home">
<div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-5">
            <h1 class="text-4xl font-medium leading-tight md:text-6xl text-center md:text-left">From Clicks to <br> Clients — We Drive <br> <span class="bg-[#b9ff66] rounded-[7px] px-2">Real Growth</span></h1>
            <p class="mt-6 mb-8 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12">TrexHub is a performance-focused digital marketing agency. We run Facebook Ads, Google Ads, SEO, Social Media, and Email Marketing strategies built for one goal — turning your audience into paying customers.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
                <a href="#contact" class="px-8 py-5 bg-zinc-900 hover:bg-[#b9ff66] hover:text-black rounded-2xl text-center text-white text-xl font-normal leading-7 transition-all duration-200">
                    Book a Free Strategy Call
                </a>
                <a href="#cases" class="px-8 py-5 border border-zinc-900 hover:bg-zinc-900 hover:text-white rounded-2xl text-center text-black text-xl font-normal leading-7 transition-all duration-200">
                    See Our Results
                </a>
            </div>
            <div class="flex flex-col sm:flex-row gap-8 justify-center md:justify-start pt-4">
                <div class="text-center md:text-left">
                    <p class="text-3xl font-medium">500K+</p>
                    <p class="text-sm text-gray-600">Leads Generated</p>
                </div>
                <div class="text-center md:text-left">
                    <p class="text-3xl font-medium">200+</p>
                    <p class="text-sm text-gray-600">Clients Served</p>
                </div>
                <div class="text-center md:text-left">
                    <p class="text-3xl font-medium">8x</p>
                    <p class="text-sm text-gray-600">Average ROAS</p>
                </div>
            </div>
        </div>
    </div>
    <div class="flex items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <Image src={HeroIlust} alt="Digital Marketing Illustration" loading="eager" />
    </div>
</div>
</Section>