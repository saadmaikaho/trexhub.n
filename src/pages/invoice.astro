---
// Private invoice generator — not linked anywhere on the site
// Password: trexhub2025
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice Generator | TrexHub</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; background: #f3f3f3; color: #191a23; }

    /* ── Login Screen ── */
    #login-screen {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-box {
      background: white;
      border-radius: 20px;
      padding: 48px;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      text-align: center;
    }
    .login-box .logo { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
    .login-box .logo span { background: #b9ff66; padding: 2px 8px; border-radius: 6px; }
    .login-box p { color: #666; margin-bottom: 28px; font-size: 14px; }
    .login-box input {
      width: 100%; padding: 14px 18px; border: 2px solid #e5e5e5;
      border-radius: 12px; font-size: 16px; margin-bottom: 12px; outline: none;
      transition: border-color 0.2s;
    }
    .login-box input:focus { border-color: #b9ff66; }
    .login-box button {
      width: 100%; padding: 14px; background: #191a23; color: white;
      border: none; border-radius: 12px; font-size: 16px; font-weight: 600;
      cursor: pointer; transition: background 0.2s;
    }
    .login-box button:hover { background: #b9ff66; color: #191a23; }
    .login-error { color: #e53e3e; font-size: 13px; margin-top: 8px; display: none; }

    /* ── App ── */
    #app { display: none; }

    .app-header {
      background: #191a23; color: white; padding: 16px 32px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .app-header .brand { font-size: 20px; font-weight: 700; }
    .app-header .brand span { color: #b9ff66; }
    .app-header button {
      padding: 8px 20px; background: #b9ff66; color: #191a23;
      border: none; border-radius: 8px; font-weight: 600; cursor: pointer;
      font-size: 14px;
    }

    .workspace {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      padding: 24px;
      max-width: 1400px;
      margin: 0 auto;
    }
    @media (max-width: 900px) {
      .workspace { grid-template-columns: 1fr; }
    }

    /* ── Form Panel ── */
    .form-panel {
      background: white; border-radius: 16px; padding: 28px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      max-height: calc(100vh - 100px); overflow-y: auto;
    }
    .form-panel h2 { font-size: 18px; font-weight: 700; margin-bottom: 20px; }
    .form-section { margin-bottom: 24px; }
    .form-section h3 {
      font-size: 13px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: #888; margin-bottom: 12px;
      padding-bottom: 8px; border-bottom: 1px solid #f0f0f0;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-group { margin-bottom: 12px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 4px; color: #444; }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 10px 14px; border: 1.5px solid #e5e5e5;
      border-radius: 10px; font-size: 14px; outline: none;
      transition: border-color 0.2s; font-family: inherit;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: #b9ff66;
    }

    /* Items table */
    .items-header {
      display: grid;
      grid-template-columns: 3fr 1fr 1fr 1fr 40px;
      gap: 8px; font-size: 12px; font-weight: 700;
      text-transform: uppercase; color: #888; margin-bottom: 8px;
    }
    .item-row {
      display: grid;
      grid-template-columns: 3fr 1fr 1fr 1fr 40px;
      gap: 8px; margin-bottom: 8px; align-items: center;
    }
    .item-row input {
      padding: 8px 10px; border: 1.5px solid #e5e5e5;
      border-radius: 8px; font-size: 13px; outline: none;
      transition: border-color 0.2s; width: 100%;
    }
    .item-row input:focus { border-color: #b9ff66; }
    .item-row input[readonly] { background: #f9f9f9; color: #555; }
    .remove-btn {
      background: #fee2e2; color: #e53e3e; border: none;
      border-radius: 8px; width: 32px; height: 32px;
      cursor: pointer; font-size: 16px; display: flex;
      align-items: center; justify-content: center;
    }
    .add-item-btn {
      background: #f3f3f3; border: 1.5px dashed #ccc; color: #555;
      padding: 10px; border-radius: 10px; width: 100%;
      cursor: pointer; font-size: 13px; font-weight: 600;
      margin-top: 4px; transition: all 0.2s;
    }
    .add-item-btn:hover { background: #b9ff66; border-color: #b9ff66; color: #191a23; }

    /* ── Preview Panel ── */
    .preview-panel {
      background: white; border-radius: 16px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      overflow: hidden;
      max-height: calc(100vh - 100px);
      overflow-y: auto;
    }
    .preview-toolbar {
      padding: 14px 20px; background: #f9f9f9;
      border-bottom: 1px solid #eee;
      display: flex; gap: 10px; align-items: center;
    }
    .preview-toolbar span { font-size: 13px; font-weight: 600; color: #555; flex: 1; }
    .btn-print {
      padding: 8px 20px; background: #191a23; color: white;
      border: none; border-radius: 8px; font-weight: 600;
      cursor: pointer; font-size: 13px; transition: background 0.2s;
    }
    .btn-print:hover { background: #b9ff66; color: #191a23; }

    /* ── Invoice Document ── */
    #invoice-doc {
      padding: 48px;
      min-height: 900px;
    }
    .inv-header {
      display: flex; justify-content: space-between;
      align-items: flex-start; margin-bottom: 40px;
    }
    .inv-brand { font-size: 26px; font-weight: 800; }
    .inv-brand span { background: #b9ff66; padding: 2px 8px; border-radius: 6px; }
    .inv-meta { text-align: right; }
    .inv-meta h1 { font-size: 32px; font-weight: 800; color: #191a23; letter-spacing: -1px; }
    .inv-meta .inv-number { font-size: 14px; color: #888; margin-top: 4px; }
    .inv-meta .inv-dates { font-size: 13px; color: #555; margin-top: 8px; line-height: 1.6; }

    .inv-parties {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 32px; margin-bottom: 36px;
    }
    .inv-party h4 {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.1em; color: #888; margin-bottom: 8px;
    }
    .inv-party p { font-size: 14px; line-height: 1.7; color: #333; }
    .inv-party .name { font-weight: 700; font-size: 16px; color: #191a23; }

    .inv-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    .inv-table thead tr { background: #191a23; color: white; }
    .inv-table thead th {
      padding: 12px 16px; text-align: left;
      font-size: 12px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .inv-table thead th:last-child { text-align: right; }
    .inv-table tbody tr { border-bottom: 1px solid #f0f0f0; }
    .inv-table tbody tr:nth-child(even) { background: #fafafa; }
    .inv-table tbody td { padding: 12px 16px; font-size: 14px; color: #333; }
    .inv-table tbody td:last-child { text-align: right; font-weight: 600; }

    .inv-totals {
      display: flex; justify-content: flex-end; margin-bottom: 36px;
    }
    .inv-totals-box { width: 280px; }
    .inv-totals-row {
      display: flex; justify-content: space-between;
      padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f0f0f0;
    }
    .inv-totals-row.total {
      background: #191a23; color: white; padding: 12px 16px;
      border-radius: 10px; margin-top: 8px; font-weight: 700; font-size: 16px;
      border: none;
    }
    .inv-totals-row label { color: #888; }

    .inv-notes {
      background: #f9f9f9; border-radius: 12px;
      padding: 16px 20px; margin-bottom: 32px;
    }
    .inv-notes h4 { font-size: 12px; font-weight: 700; text-transform: uppercase; color: #888; margin-bottom: 6px; }
    .inv-notes p { font-size: 13px; color: #555; line-height: 1.6; }

    .inv-footer {
      text-align: center; padding-top: 24px;
      border-top: 1px solid #f0f0f0;
      font-size: 12px; color: #aaa;
    }

    /* ── Print styles ── */
    @media print {
      body { background: white; }
      #login-screen { display: none !important; }
      .app-header, .form-panel, .preview-toolbar { display: none !important; }
      #app { display: block !important; }
      .workspace { display: block; padding: 0; }
      .preview-panel {
        box-shadow: none; border-radius: 0;
        max-height: none; overflow: visible;
      }
      #invoice-doc { padding: 32px; }
    }
  </style>
</head>
<body>

<!-- ── LOGIN ── -->
<div id="login-screen">
  <div class="login-box">
    <div class="logo">Trex<span>Hub</span></div>
    <p>Invoice Generator — Admin Access</p>
    <input type="password" id="pwd-input" placeholder="Enter password" />
    <div class="login-error" id="login-error">Incorrect password. Try again.</div>
    <button onclick="checkPassword()">Enter</button>
  </div>
</div>

<!-- ── APP ── -->
<div id="app">
  <div class="app-header">
    <div class="brand">Trex<span>Hub</span> — Invoice Generator</div>
    <button onclick="window.print()">🖨️ Print / Save PDF</button>
  </div>

  <div class="workspace">

    <!-- FORM -->
    <div class="form-panel">
      <h2>Invoice Details</h2>

      <div class="form-section">
        <h3>Invoice Info</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Invoice Number</label>
            <input type="text" id="inv-number" value="INV-001" oninput="updatePreview()" />
          </div>
          <div class="form-group">
            <label>Currency</label>
            <select id="inv-currency" onchange="updatePreview()">
              <option value="₦">Naira (₦)</option>
              <option value="$">USD ($)</option>
              <option value="€">EUR (€)</option>
              <option value="£">GBP (£)</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Issue Date</label>
            <input type="date" id="inv-date" oninput="updatePreview()" />
          </div>
          <div class="form-group">
            <label>Due Date</label>
            <input type="date" id="inv-due" oninput="updatePreview()" />
          </div>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select id="inv-status" onchange="updatePreview()">
            <option value="Due">Due</option>
            <option value="Paid">Paid</option>
            <option value="Overdue">Overdue</option>
          </select>
        </div>
      </div>

      <div class="form-section">
        <h3>Bill To (Client)</h3>
        <div class="form-group">
          <label>Client Name / Company</label>
          <input type="text" id="client-name" placeholder="e.g. Acme Ltd" oninput="updatePreview()" />
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" id="client-email" placeholder="client@email.com" oninput="updatePreview()" />
        </div>
        <div class="form-group">
          <label>Phone</label>
          <input type="text" id="client-phone" placeholder="+234 800 000 0000" oninput="updatePreview()" />
        </div>
        <div class="form-group">
          <label>Address</label>
          <textarea id="client-address" rows="2" placeholder="Client address" oninput="updatePreview()"></textarea>
        </div>
      </div>

      <div class="form-section">
        <h3>Services / Items</h3>
        <div class="items-header">
          <span>Description</span>
          <span>Qty</span>
          <span>Rate</span>
          <span>Amount</span>
          <span></span>
        </div>
        <div id="items-container"></div>
        <button class="add-item-btn" onclick="addItem()">+ Add Item</button>
      </div>

      <div class="form-section">
        <h3>Tax & Discount</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Tax (%)</label>
            <input type="number" id="inv-tax" value="0" min="0" max="100" oninput="updatePreview()" />
          </div>
          <div class="form-group">
            <label>Discount (%)</label>
            <input type="number" id="inv-discount" value="0" min="0" max="100" oninput="updatePreview()" />
          </div>
        </div>
      </div>

      <div class="form-section">
        <h3>Payment & Notes</h3>
        <div class="form-group">
          <label>Bank / Payment Details</label>
          <textarea id="inv-bank" rows="3" placeholder="Bank: GTBank&#10;Account Name: TrexHub Digital&#10;Account Number: 0123456789" oninput="updatePreview()"></textarea>
        </div>
        <div class="form-group">
          <label>Notes</label>
          <textarea id="inv-notes" rows="2" placeholder="Thank you for your business!" oninput="updatePreview()"></textarea>
        </div>
      </div>
    </div>

    <!-- PREVIEW -->
    <div class="preview-panel">
      <div class="preview-toolbar">
        <span>📄 Live Preview</span>
        <button class="btn-print" onclick="window.print()">Print / Save as PDF</button>
      </div>
      <div id="invoice-doc">
        <!-- rendered by JS -->
      </div>
    </div>

  </div>
</div>

<script>
  const PASSWORD = "trexhub2025";

  // ── Auth ──
  function checkPassword() {
    const val = document.getElementById("pwd-input").value;
    if (val === PASSWORD) {
      document.getElementById("login-screen").style.display = "none";
      document.getElementById("app").style.display = "block";
      init();
    } else {
      document.getElementById("login-error").style.display = "block";
    }
  }
  document.getElementById("pwd-input").addEventListener("keydown", e => {
    if (e.key === "Enter") checkPassword();
  });

  // ── Items ──
  let items = [
    { desc: "", qty: 1, rate: 0 }
  ];

  function addItem() {
    items.push({ desc: "", qty: 1, rate: 0 });
    renderItems();
    updatePreview();
  }

  function removeItem(i) {
    items.splice(i, 1);
    renderItems();
    updatePreview();
  }

  function renderItems() {
    const container = document.getElementById("items-container");
    container.innerHTML = items.map((item, i) => `
      <div class="item-row">
        <input type="text" placeholder="Service description" value="${item.desc}"
          oninput="items[${i}].desc=this.value;updatePreview()" />
        <input type="number" min="1" value="${item.qty}"
          oninput="items[${i}].qty=parseFloat(this.value)||0;calcAmount(${i})" />
        <input type="number" min="0" value="${item.rate}"
          oninput="items[${i}].rate=parseFloat(this.value)||0;calcAmount(${i})" />
        <input type="text" id="amount-${i}" readonly value="${fmt(item.qty * item.rate)}" />
        <button class="remove-btn" onclick="removeItem(${i})">×</button>
      </div>
    `).join("");
  }

  function calcAmount(i) {
    const el = document.getElementById(`amount-${i}`);
    if (el) el.value = fmt(items[i].qty * items[i].rate);
    updatePreview();
  }

  // ── Format ──
  function fmt(n) {
    return parseFloat(n || 0).toLocaleString("en-NG", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function getCurrency() {
    return document.getElementById("inv-currency")?.value || "₦";
  }

  // ── Preview ──
  function updatePreview() {
    const cur = getCurrency();
    const number = document.getElementById("inv-number")?.value || "INV-001";
    const date = document.getElementById("inv-date")?.value || "";
    const due = document.getElementById("inv-due")?.value || "";
    const status = document.getElementById("inv-status")?.value || "Due";
    const clientName = document.getElementById("client-name")?.value || "Client Name";
    const clientEmail = document.getElementById("client-email")?.value || "";
    const clientPhone = document.getElementById("client-phone")?.value || "";
    const clientAddr = document.getElementById("client-address")?.value || "";
    const taxPct = parseFloat(document.getElementById("inv-tax")?.value) || 0;
    const discPct = parseFloat(document.getElementById("inv-discount")?.value) || 0;
    const bank = document.getElementById("inv-bank")?.value || "";
    const notes = document.getElementById("inv-notes")?.value || "";

    const subtotal = items.reduce((s, it) => s + (it.qty * it.rate), 0);
    const discAmt = subtotal * discPct / 100;
    const taxAmt = (subtotal - discAmt) * taxPct / 100;
    const total = subtotal - discAmt + taxAmt;

    const statusColor = status === "Paid" ? "#22c55e" : status === "Overdue" ? "#ef4444" : "#f59e0b";

    const formatDate = d => d ? new Date(d).toLocaleDateString("en-GB", { day:"2-digit", month:"short", year:"numeric" }) : "—";

    const rows = items.map(it => `
      <tr>
        <td>${it.desc || "—"}</td>
        <td>${it.qty}</td>
        <td>${cur}${fmt(it.rate)}</td>
        <td>${cur}${fmt(it.qty * it.rate)}</td>
      </tr>
    `).join("");

    document.getElementById("invoice-doc").innerHTML = `
      <div class="inv-header">
        <div>
          <div class="inv-brand">Trex<span>Hub</span></div>
          <div style="font-size:13px;color:#666;margin-top:6px;line-height:1.6">
            Victoria Island, Lagos, Nigeria<br/>
            hello@trexhub.ng &nbsp;|&nbsp; +234 8129843426<br/>
            trexhub.ng
          </div>
        </div>
        <div class="inv-meta">
          <h1>INVOICE</h1>
          <div class="inv-number">${number}</div>
          <div style="margin-top:8px">
            <span style="background:${statusColor};color:white;padding:3px 12px;border-radius:20px;font-size:12px;font-weight:700">${status}</span>
          </div>
          <div class="inv-dates">
            Issue Date: <strong>${formatDate(date)}</strong><br/>
            Due Date: <strong>${formatDate(due)}</strong>
          </div>
        </div>
      </div>

      <div class="inv-parties">
        <div class="inv-party">
          <h4>From</h4>
          <p class="name">TrexHub Digital Marketing Agency</p>
          <p>Victoria Island, Lagos, Nigeria<br/>hello@trexhub.ng<br/>+234 8129843426</p>
        </div>
        <div class="inv-party">
          <h4>Bill To</h4>
          <p class="name">${clientName}</p>
          <p>${[clientEmail, clientPhone, clientAddr].filter(Boolean).join("<br/>")}</p>
        </div>
      </div>

      <table class="inv-table">
        <thead>
          <tr>
            <th>Description</th>
            <th>Qty</th>
            <th>Rate</th>
            <th>Amount</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>

      <div class="inv-totals">
        <div class="inv-totals-box">
          <div class="inv-totals-row"><label>Subtotal</label><span>${cur}${fmt(subtotal)}</span></div>
          ${discPct > 0 ? `<div class="inv-totals-row"><label>Discount (${discPct}%)</label><span>− ${cur}${fmt(discAmt)}</span></div>` : ""}
          ${taxPct > 0 ? `<div class="inv-totals-row"><label>Tax (${taxPct}%)</label><span>${cur}${fmt(taxAmt)}</span></div>` : ""}
          <div class="inv-totals-row total"><label>Total Due</label><span>${cur}${fmt(total)}</span></div>
        </div>
      </div>

      ${bank ? `
        <div class="inv-notes">
          <h4>Payment Details</h4>
          <p style="white-space:pre-line">${bank}</p>
        </div>
      ` : ""}

      ${notes ? `
        <div class="inv-notes">
          <h4>Notes</h4>
          <p>${notes}</p>
        </div>
      ` : ""}

      <div class="inv-footer">
        Thank you for choosing TrexHub. &nbsp;|&nbsp; trexhub.ng &nbsp;|&nbsp; hello@trexhub.ng
      </div>
    `;
  }

  function init() {
    // Set today's date and due date (+30 days)
    const today = new Date();
    const due = new Date();
    due.setDate(due.getDate() + 30);
    document.getElementById("inv-date").value = today.toISOString().split("T")[0];
    document.getElementById("inv-due").value = due.toISOString().split("T")[0];
    renderItems();
    updatePreview();
  }
</script>

</body>
</html>
