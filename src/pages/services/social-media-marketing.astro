---
import MainLayout from "../../layouts/MainLayout.astro";
import Card from "../../components/ui/Card.astro";
import { Image } from "astro:assets";

import serviceImg from "../../assets/pics/card-pic4.png";
import icon1 from "../../assets/icon1.svg";
import icon2 from "../../assets/icon2.svg";
import icon3 from "../../assets/icon3.svg";
import icon4 from "../../assets/icon4.svg";

const platforms = [
  { name: "Instagram", desc: "Reels, Stories, carousels, and feed posts that build brand identity and drive engagement." },
  { name: "Facebook", desc: "Page management, community building, and organic content that keeps your audience warm." },
  { name: "LinkedIn", desc: "Thought leadership content and B2B positioning for professional services and corporate brands." },
  { name: "TikTok", desc: "Short-form video content that reaches younger audiences and drives viral brand awareness." },
  { name: "Twitter / X", desc: "Real-time engagement, trending conversations, and brand voice development." },
  { name: "YouTube", desc: "Long-form video strategy, channel management, and SEO-optimised video content." },
];

const includes = [
  {
    title: "Content Strategy",
    items: ["Monthly content calendar", "Brand voice & tone guidelines", "Competitor & trend analysis", "Content pillars & themes"],
  },
  {
    title: "Content Creation",
    items: ["Graphic design & visuals", "Copywriting & captions", "Reels & short-form video scripts", "Hashtag research & strategy"],
  },
  {
    title: "Community Management",
    items: ["Daily comment & DM responses", "Audience engagement & growth", "Brand reputation monitoring", "Influencer collaboration outreach"],
  },
];

const process = [
  { title: "Brand Audit & Strategy", description: "We review your current social presence, define your brand voice, and build a content strategy aligned with your business goals.", icon: icon1 },
  { title: "Content Production", description: "Our creative team produces scroll-stopping graphics, captions, and video content tailored to each platform's algorithm and audience.", icon: icon2 },
  { title: "Publish & Engage", description: "We post consistently, respond to comments and DMs, and actively grow your community through genuine engagement.", icon: icon3 },
  { title: "Analyse & Optimise", description: "Monthly performance reports covering reach, engagement, follower growth, and conversions — with clear recommendations for improvement.", icon: icon4 },
];

const faqs = [
  { question: "How many posts per week do you create?", answer: "Our standard package includes 4–5 posts per week across your chosen platforms. We can increase frequency based on your package and goals." },
  { question: "Do you manage all our social media platforms?", answer: "We can manage any combination of platforms. We'll recommend the right ones based on where your target audience spends time and your business type." },
  { question: "Will I need to approve content before it goes live?", answer: "Yes. We share a monthly content calendar for your review and approval before scheduling. You stay in control while we handle the heavy lifting." },
  { question: "Can social media marketing generate leads and sales?", answer: "Absolutely. Organic social builds trust and keeps your brand top-of-mind. Combined with paid social ads, it becomes a powerful lead generation and sales channel." },
];
---

<MainLayout
  title="Social Media Marketing & Management in Lagos | TrexHub"
  description="Build a powerful social media presence with TrexHub. We manage your Instagram, Facebook, TikTok, LinkedIn, and more — creating content that engages and converts."
>
  <div class="py-16 px-4 mx-auto max-w-screen-xl lg:py-24 lg:px-6">

    <!-- Hero -->
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24">
      <div>
        <span class="inline-block bg-[#b9ff66] text-black text-sm font-medium px-4 py-1 rounded-full mb-4">Social Media Marketing</span>
        <h1 class="mb-6 text-4xl font-medium leading-tight md:text-5xl lg:text-6xl">Social Media That Builds Brands and Drives Sales</h1>
        <p class="mb-8 text-lg font-normal text-gray-700">
          Your audience is on social media every day. TrexHub creates and manages content that builds your brand, grows your following, and turns followers into customers.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/#contact" class="inline-flex items-center justify-center px-8 py-4 bg-black text-white rounded-2xl hover:bg-[#b9ff66] hover:text-black transition-all font-medium text-lg">
            Grow My Social Media
          </a>
          <a href="#platforms" class="inline-flex items-center justify-center px-8 py-4 bg-[#f3f3f3] text-black rounded-2xl hover:bg-black hover:text-white transition-all font-medium text-lg">
            Platforms We Manage
          </a>
        </div>
      </div>
      <div class="relative">
        <div class="bg-[#b9ff66] rounded-[45px] p-4 md:p-8 relative z-10">
          <Image src={serviceImg} alt="Social Media Marketing" class="w-full h-auto rounded-[35px]" />
        </div>
        <div class="absolute top-8 left-8 right-8 bottom-8 bg-black rounded-[45px] -z-10"></div>
      </div>
    </div>

    <!-- Platforms -->
    <div class="mb-24" id="platforms">
      <h2 class="mb-4 text-3xl font-medium text-center">Platforms We Manage</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">We manage your presence across every major social platform with platform-specific strategies.</p>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {platforms.map((p) => (
          <div class="bg-[#f3f3f3] rounded-2xl p-6">
            <h3 class="text-lg font-medium mb-2">{p.name}</h3>
            <p class="text-sm text-gray-600">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- What's included -->
    <div class="mb-24">
      <h2 class="mb-4 text-3xl font-medium text-center">What's Included</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">A complete done-for-you social media management service.</p>
      <div class="grid md:grid-cols-3 gap-8">
        {includes.map((col) => (
          <Card>
            <div class="p-8">
              <h3 class="text-xl font-medium mb-5">{col.title}</h3>
              <ul class="space-y-3">
                {col.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="w-2 h-2 rounded-full bg-[#b9ff66] flex-shrink-0 mt-2"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <!-- Process -->
    <div class="mb-24">
      <h2 class="mb-12 text-3xl font-medium text-center">Our Process</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map((step, i) => (
          <div class="bg-[#f3f3f3] rounded-2xl p-8 relative">
            <div class="absolute -top-5 left-8 bg-black text-white w-10 h-10 rounded-full flex items-center justify-center font-medium">{i + 1}</div>
            <Image src={step.icon} alt={step.title} class="h-10 w-auto mb-4 mt-2" />
            <h3 class="text-lg font-medium mb-3">{step.title}</h3>
            <p class="text-sm text-gray-600">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- FAQs -->
    <div class="mb-24">
      <h2 class="mb-12 text-3xl font-medium text-center">Frequently Asked Questions</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {faqs.map((faq) => (
          <Card>
            <div class="p-8">
              <h3 class="text-lg font-medium mb-3">{faq.question}</h3>
              <p class="text-gray-600">{faq.answer}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <Card>
      <div class="p-10 md:p-16 text-center">
        <h2 class="text-3xl md:text-4xl font-medium mb-4">Ready to build a social media presence that converts?</h2>
        <p class="mb-8 text-lg text-gray-600 max-w-2xl mx-auto">Book a free strategy call and we'll audit your current social media and show you exactly how to grow.</p>
        <a href="/#contact" class="inline-flex items-center px-10 py-5 bg-black text-white rounded-2xl hover:bg-[#b9ff66] hover:text-black transition-all font-medium text-xl">
          Book a Free Strategy Call
        </a>
      </div>
    </Card>

  </div>
</MainLayout>
