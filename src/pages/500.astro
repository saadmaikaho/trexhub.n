---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Server Error | TrexLead">
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-20">
    <div class="text-center max-w-lg mx-auto">

      <!-- Big 500 -->
      <div class="relative mb-8">
        <p class="text-[160px] md:text-[200px] font-medium leading-none text-[#f3f3f3] select-none">500</p>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="bg-black text-white text-sm font-medium px-4 py-1 rounded-full">Server Error</span>
        </div>
      </div>

      <h1 class="text-3xl md:text-4xl font-medium mb-4">Something went wrong on our end</h1>
      <p class="text-gray-500 text-lg mb-10">
        We're aware of the issue and working to fix it. Please try again in a few minutes.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-8 py-4 bg-black hover:bg-[#b9ff66] hover:text-black text-white rounded-2xl text-lg font-medium transition-all duration-200">
          Back to Home
        </a>
        <a
          href="https://wa.me/2348129843426?text=Hi%20TrexLead%2C%20I%27m%20getting%20a%20500%20error%20on%20your%20website."
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 border border-black hover:bg-black hover:text-white text-black rounded-2xl text-lg font-medium transition-all duration-200"
        >
          Report via WhatsApp
        </a>
      </div>

      <p class="mt-10 text-sm text-gray-400">
        If the problem persists, email us at
        <a href="mailto:hello@trexlead.ng" class="text-black underline hover:text-[#b9ff66]">hello@trexlead.ng</a>
      </p>

    </div>
  </div>
</MainLayout>
